# 階段 1：構建 React 靜態檔案
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# 定義建置變數以覆蓋 API 網址，在生產環境中使用相對路徑
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build

# 階段 2：使用 Nginx 提供網頁與反向代理服務
FROM nginx:alpine

# 複製構建完成的靜態檔案到 Nginx html 目錄
COPY --from=builder /app/dist /usr/share/nginx/html

# 複製 Nginx 設定檔
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
